---
const { dir, pagination } = Astro.locals.starlightRoute;
const { prev, next } = pagination;
const isRtl = dir === 'rtl';
---

<div class="pagination-links print:hidden" dir={dir}>
	{
		prev && (
			<a href={prev.href} rel="prev">
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
				<span>
					{Astro.locals.t('page.previousLink')}
					<br />
					<span class="link-title">{prev.label}</span>
				</span>
			</a>
		)
	}
	{
		next && (
			<a href={next.href} rel="next">
				<span>
					{Astro.locals.t('page.nextLink')}
					<br />
					<span class="link-title">{next.label}</span>
				</span>
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
			</a>
		)
	}
</div>

<style>
	.pagination-links {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		margin: 1.5rem 0;
		padding: 1rem 0;
		border-top: 1px solid var(--sl-color-hairline-light);
		border-bottom: 1px solid var(--sl-color-hairline-light);
	}

	.pagination-links a {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		width: auto;
		flex-basis: auto;
		flex-grow: 0;
		font-size: 0.8rem;
		font-weight: 500;
		color: var(--sl-color-text-accent);
		text-decoration: none !important;
		padding: 0.4rem 0.6rem;
		border: none !important;
		border-radius: 4px;
		box-shadow: none !important;
		overflow-wrap: normal;
		transition: all 0.15s;
		background: transparent;
	}
	.pagination-links a:hover {
		background: var(--sl-color-accent-low);
		color: var(--sl-color-text-accent);
		text-decoration: none !important;
	}

	[rel='next'] {
		flex-direction: row-reverse;
		text-align: right;
	}

	.pagination-links .link-title {
		font-size: 0.85rem;
		font-weight: 600;
		line-height: 1.2;
		color: var(--sl-color-text-accent);
	}

	.pagination-links svg {
		flex-shrink: 0;
		width: 1rem;
		height: 1rem;
	}
</style>